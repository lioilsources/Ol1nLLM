# Copy to .env and fill in secrets before first run.
# cp backend/.env.example backend/.env

# ── Auth ─────────────────────────────────────────────────────
HF_TOKEN=hf_...

# ── Cache paths (host absolute paths) ────────────────────────
CACHE_FLUX=/home/ol1n/Code/Github/ai-stack/cache/flux
CACHE_QWEN_IMAGE=/home/ol1n/llm-stack/cache/img
CACHE_QWEN_VL=/home/ol1n/Code/Github/ai-stack/cache/qwen-vl

# ── Image API ─────────────────────────────────────────────────
FLUX_MODEL_ID=black-forest-labs/FLUX.1-dev
QWEN_IMAGE_MODEL_ID=Qwen/Qwen-Image-Edit-2511
FLUX_FP8=0
# Set to 0 to skip loading a pipeline (saves GPU memory):
LOAD_FLUX=1
LOAD_QWEN_IMAGE=1
# NSFW LoRA: run scripts/download_flux_lora.sh first.
# Default is SFW; request the nsfw variant per-call with {"nsfw": true}.
LOAD_FLUX_LORA=1
FLUX_NSFW_LORA=/root/.cache/huggingface/flux/lora/lora.safetensors
FLUX_NSFW_LORA_SCALE=1.0

# ── OCR API ───────────────────────────────────────────────────
OCR_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct
