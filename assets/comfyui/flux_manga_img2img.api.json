{
  "10": {
    "class_type": "UNETLoader",
    "_meta": { "title": "Load FLUX Kontext UNET" },
    "inputs": {
      "unet_name": "flux1-dev-kontext_fp8_scaled.safetensors",
      "weight_dtype": "fp8_e4m3fn"
    }
  },
  "11": {
    "class_type": "DualCLIPLoader",
    "_meta": { "title": "Load FLUX CLIP (T5 + CLIP-L)" },
    "inputs": {
      "clip_name1": "t5xxl_fp16.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    }
  },
  "12": {
    "class_type": "VAELoader",
    "_meta": { "title": "Load FLUX VAE" },
    "inputs": { "vae_name": "ae.safetensors" }
  },
  "14": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Edit instruction (positive)" },
    "inputs": {
      "text": "__PROMPT__",
      "clip": ["11", 0]
    }
  },
  "15": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative (unused on FLUX, kept for CFG=1)" },
    "inputs": {
      "text": "",
      "clip": ["11", 0]
    }
  },
  "16": {
    "class_type": "FluxGuidance",
    "_meta": { "title": "FLUX Guidance" },
    "inputs": {
      "guidance": 3.5,
      "conditioning": ["14", 0]
    }
  },
  "30": {
    "class_type": "LoadImage",
    "_meta": { "title": "Load uploaded image" },
    "inputs": {
      "image": "__IMAGE__",
      "upload": "image"
    }
  },
  "31": {
    "class_type": "FluxKontextImageScale",
    "_meta": { "title": "Scale to Kontext-optimal resolution" },
    "inputs": {
      "image": ["30", 0]
    }
  },
  "32": {
    "class_type": "VAEEncode",
    "_meta": { "title": "Encode reference image" },
    "inputs": {
      "pixels": ["31", 0],
      "vae": ["12", 0]
    }
  },
  "33": {
    "class_type": "ReferenceLatent",
    "_meta": { "title": "Attach reference to conditioning" },
    "inputs": {
      "conditioning": ["16", 0],
      "latent": ["32", 0]
    }
  },
  "34": {
    "class_type": "EmptySD3LatentImage",
    "_meta": { "title": "Target latent (batch)" },
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 4
    }
  },
  "18": {
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (Kontext: full denoise, reference guides output)" },
    "inputs": {
      "seed": 0,
      "steps": 28,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["10", 0],
      "positive": ["33", 0],
      "negative": ["15", 0],
      "latent_image": ["34", 0]
    }
  },
  "19": {
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" },
    "inputs": {
      "samples": ["18", 0],
      "vae": ["12", 0]
    }
  },
  "20": {
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" },
    "inputs": {
      "filename_prefix": "ol1n_manga_edit",
      "images": ["19", 0]
    }
  }
}
