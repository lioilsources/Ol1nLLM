{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Pony Checkpoint" },
    "inputs": { "ckpt_name": "ponyDiffusionV6XL_v6StartWithThisOne.safetensors" }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive prompt" },
    "inputs": {
      "text": "__PROMPT__",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative prompt" },
    "inputs": {
      "text": "score_4, score_5, score_6, bad quality, worst quality, low quality, jpeg artifacts, blurry, ugly, watermark",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty latent (batch)" },
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 4
    }
  },
  "5": {
    "class_type": "KSampler",
    "_meta": { "title": "KSampler" },
    "inputs": {
      "seed": 0,
      "steps": 30,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0]
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" },
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" },
    "inputs": {
      "filename_prefix": "ol1n_pony",
      "images": ["6", 0]
    }
  }
}
