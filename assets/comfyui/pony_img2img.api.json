{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Pony Checkpoint" },
    "inputs": { "ckpt_name": "ponyDiffusionV6XL_v6StartWithThisOne.safetensors" }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Edit instruction (positive)" },
    "inputs": {
      "text": "score_9, score_8_up, score_7_up, score_6_up, __PROMPT__",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative prompt" },
    "inputs": {
      "text": "score_4, score_5, score_6, bad quality, worst quality, low quality, jpeg artifacts, blurry, ugly, watermark",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "LoadImage",
    "_meta": { "title": "Load uploaded image" },
    "inputs": {
      "image": "__IMAGE__",
      "upload": "image"
    }
  },
  "5": {
    "class_type": "VAEEncode",
    "_meta": { "title": "VAE Encode (img2img)" },
    "inputs": {
      "pixels": ["4", 0],
      "vae": ["1", 2]
    }
  },
  "6": {
    "class_type": "RepeatLatentBatch",
    "_meta": { "title": "Repeat latent → batch" },
    "inputs": {
      "amount": 4,
      "samples": ["5", 0]
    }
  },
  "7": {
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (denoise < 1)" },
    "inputs": {
      "seed": 0,
      "steps": 30,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.72,
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["6", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" },
    "inputs": {
      "samples": ["7", 0],
      "vae": ["1", 2]
    }
  },
  "9": {
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" },
    "inputs": {
      "filename_prefix": "ol1n_pony_edit",
      "images": ["8", 0]
    }
  }
}
